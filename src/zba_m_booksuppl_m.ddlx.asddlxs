annotate entity ZBA_C_BOOKSUPPL_M with
{

//  @UI.facet: [{ id : 'idSupplement', label: 'FL Supplements', position: 10, purpose: #STANDARD, type: #IDENTIFICATION_REFERENCE}]
   @UI.facet: [{ id:'idCollection1', purpose: #STANDARD, type: #COLLECTION, position: 10, label: 'Supplement Detatils - Collection1' },
               { id:'idFG1', purpose: #STANDARD, type: #FIELDGROUP_REFERENCE, parentId: 'idCollection1', position: 10, label: 'FG1 Label', targetQualifier: 'TGQ1'},
               { id:'idFG2', purpose: #STANDARD, type: #FIELDGROUP_REFERENCE, parentId: 'idCollection1', position: 20, label: 'FG2 Label', targetQualifier: 'TGQ2'}
             
              ]
  
    //    TravelId;
    //    BookingId;
  @UI : { lineItem: [{ position: 10 }]
//          identification: [{ position: 10 }] 
         }
