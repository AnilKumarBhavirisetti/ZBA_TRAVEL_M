  Price;
  @UI : { lineItem: [{ position: 40 }]
//          identification: [{ position: 40 }] 
        }
  @Consumption.valueHelpDefinition: [{ entity: {
                                           name: 'I_Currency',
                                           element: 'Currency'
                                       } }]
  @UI.fieldGroup: [{ position: 20,qualifier: 'TGQ2' }]
  CurrencyCode;
  //    CurrencyName;
  @UI.hidden: true
  LastChangedAt;


}